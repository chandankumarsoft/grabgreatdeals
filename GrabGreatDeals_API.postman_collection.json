{
  "info": {
    "name": "GrabGreatDeals API",
    "description": "Complete REST API collection for GrabGreatDeals eCommerce platform.\n\nBase URL: http://localhost:8080/api/v1\n\nAuth: After logging in, copy the `token` from the response and set the `token` collection variable. All authenticated requests use Bearer token automatically via the collection variable.\n\nTest credentials:\n- Admin:    admin@grabgreatdeals.com / Admin@1234\n- Customer: customer@grabgreatdeals.com / Customer@1234",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password@1234\",\n  \"password_confirm\": \"Password@1234\"\n}"
            }
          }
        },
        {
          "name": "Login (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@grabgreatdeals.com\",\n  \"password\": \"Customer@1234\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data && json.data.token) {",
                  "  pm.collectionVariables.set('token', json.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@grabgreatdeals.com\",\n  \"password\": \"Admin@1234\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": {"type": "bearer", "bearer": [{"key": "token", "value": "{{token}}", "type": "string"}]},
            "method": "POST",
            "url": "{{base_url}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Products (Public)",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                {"key": "page", "value": "1", "disabled": true},
                {"key": "per_page", "value": "15", "disabled": true},
                {"key": "category", "value": "electronics", "disabled": true},
                {"key": "search", "value": "earbuds", "disabled": true},
                {"key": "featured", "value": "1", "disabled": true},
                {"key": "min_price", "value": "10", "disabled": true},
                {"key": "max_price", "value": "200", "disabled": true},
                {"key": "min_rating", "value": "4", "disabled": true},
                {"key": "in_stock", "value": "1", "disabled": true},
                {"key": "on_sale", "value": "1", "disabled": true},
                {"key": "sort", "value": "price", "disabled": true, "description": "price | name | rating | popularity | created_at"},
                {"key": "order", "value": "ASC", "disabled": true, "description": "ASC | DESC"}
              ]
            }
          }
        },
        {
          "name": "Get Product by Slug",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/products/wireless-bluetooth-earbuds"
          }
        },
        {
          "name": "Get Product Reviews",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products/1/reviews",
              "host": ["{{base_url}}"],
              "path": ["products", "1", "reviews"],
              "query": [
                {"key": "page", "value": "1", "disabled": true},
                {"key": "per_page", "value": "10", "disabled": true}
              ]
            }
          }
        }
      ]
    },
